# ==========================================================================
# Shared -- same variables regardless of deployment target (Vercel or
# self-hosted/Docker, see README's "Self-hosted deployment (Docker)").
# ==========================================================================

# Postgres, with the pgvector extension. On Vercel: Neon via Vercel
# Marketplace. Self-hosted: the bundled `postgres` service in
# docker-compose.yml (built automatically from POSTGRES_USER/PASSWORD/DB
# below -- you don't set POSTGRES_URL directly for Docker).
POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# Secret used to encrypt the session cookie (the user's GitLab/LLM tokens).
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Auth.js (Google sign-in) — see README "Authentication setup" for the full setup steps.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: ANTHROPIC_API_KEY for personal/local use, so you don't have to enter an
# LLM provider token in Settings every session. A token entered in Settings takes
# priority over this if both are set.
ANTHROPIC_API_KEY=

# Platform key for document embeddings (Voyage AI, since Claude has no embeddings
# API of its own) — https://www.voyageai.com. This is NOT a per-user token.
VOYAGE_API_KEY=

# Figma OAuth app -- one app for the whole deployment, see README's Figma
# setup section for how to register it. What's per-user is the resulting
# access token (each person connects their own Figma account from
# /design-system/settings) -- never set per-user here.
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# GitHub write access to the separate design-system repo (real React/CSS
# component code generated from Figma, see README's "Design system code
# sync" section). A fine-grained PAT scoped to ONLY that repo, with
# Contents: Read and write + Pull requests: Read and write -- company-wide,
# same reasoning as VOYAGE_API_KEY/FIGMA_CLIENT_ID above (this is a
# platform action, not a personal one). Optional: the whole code-sync
# feature is skipped if unset.
GITHUB_TOKEN=
GITHUB_DESIGN_SYSTEM_REPO=D-2-G-8/design-system
# Defaults to "master" if unset -- only needed if the design-system repo's
# base branch is named something else.
GITHUB_DESIGN_SYSTEM_BASE_BRANCH=

# Base URL of the design-system repo's own Storybook deployment (a
# SEPARATE Vercel project pointed at that repo's build-storybook output --
# see README's "Design system code sync" section). No trailing slash. The
# component detail page embeds a live preview iframe once this is set;
# optional -- component pages just show a "set this to preview" note if
# unset. NOT the same project/URL as this app's own Vercel deployment.
DESIGN_SYSTEM_STORYBOOK_URL=

# ==========================================================================
# File storage driver
# ==========================================================================

# "vercel-blob" (default if unset -- every existing Vercel deployment needs
# no other change) or "s3" (self-hosted/Docker, or pointing at real AWS S3
# from anywhere). See src/lib/storage/.
STORAGE_DRIVER=vercel-blob

# ==========================================================================
# Vercel-only -- set automatically by Vercel once Blob storage is
# connected (Storage -> Blob). Leave unset for self-hosted deployments.
# ==========================================================================
BLOB_READ_WRITE_TOKEN=

# ==========================================================================
# S3-compatible storage -- only required when STORAGE_DRIVER=s3.
# For the bundled docker-compose MinIO service these are set from the
# MINIO_* variables below and you don't need to fill these in separately;
# they're listed here for reference and for pointing at real AWS S3 instead.
# ==========================================================================
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=ai-tools-app
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Required "true" for MinIO; unset or "false" for real AWS S3.
S3_FORCE_PATH_STYLE=true

# ==========================================================================
# docker-compose only -- used to build POSTGRES_URL and the S3_* variables
# above for the bundled postgres/minio services. Not read directly by the
# app itself. Ignored for Vercel deployments.
# ==========================================================================
POSTGRES_USER=ai_tools_app
POSTGRES_PASSWORD=
POSTGRES_DB=ai_tools_app
MINIO_ROOT_USER=ai_tools_app
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=ai-tools-app

# Visual review (Increment 2): external screenshot service key + the per-branch
# Storybook stand template ({branch} is substituted with the Vercel branch slug).
SCREENSHOT_API_KEY=
# SCREENSHOT_API_URL=https://api.screenshotone.com/take
DESIGN_SYSTEM_STORYBOOK_URL_TEMPLATE=https://design-system-git-{branch}-YOUR-TEAM.vercel.app
