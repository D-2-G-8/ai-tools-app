# Требовать, чтобы версия Node соответствовала "engines" в package.json —
# чтобы локальная разработка не расходилась с рантаймом Vercel.
engine-strict=true

# Не падать/не спрашивать интерактивно из-за конфликтов peer-зависимостей —
# удобно для небольшого проекта с быстро меняющимся набором пакетов.
auto-install-peers=true
strict-peer-dependencies=false

# Не поднимать в корень node_modules пакеты, которые явно не объявлены в
# package.json — предсказуемое дерево зависимостей (стандартное поведение pnpm).
shamefully-hoist=false

registry=https://registry.npmjs.org/